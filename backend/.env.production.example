NODE_ENV=production
PORT=5000

DATABASE_URL="postgresql://USER:PASSWORD@RDS_OR_DB_HOST:5432/roboking_crm?schema=public"
JWT_SECRET="replace_with_64_plus_random_characters"
JWT_EXPIRES_IN=12h

FRONTEND_URL=https://mint.roboking.in
API_PUBLIC_URL=https://api-mint.roboking.in/api

ADMIN_BCC_EMAIL=monit.roboking@gmail.com

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_with_iam_access_key_or_use_instance_role
AWS_SECRET_ACCESS_KEY=replace_with_iam_secret_or_use_instance_role
AWS_S3_BUCKET=roboking-crm-production-files

MAX_UPLOAD_BYTES=52428800
MAX_CALL_RECORDING_BYTES=52428800

HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=465
HOSTINGER_IMAP_HOST=imap.hostinger.com
HOSTINGER_IMAP_PORT=993
